SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=documents

# For running migrations (pick one):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres
SUPABASE_DB_PASSWORD=your_database_password

OPENROUTER_API_KEY=your_openrouter_api_key
# Optional: comma-separated keys for failover
# OPENROUTER_API_KEY=sk-or-key_one,sk-or-key_two
# Free models end with :free — browse at https://openrouter.ai/models
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Learning Assistant

JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
MAX_FILE_SIZE=10485760
PORT=8000
NODE_ENV=development

# Production URLs
# Public API URL (no trailing slash, no /api suffix)
# Example: https://your-api.onrender.com
API_BASE_URL=http://localhost:8000
# Comma-separated allowed frontend origins for CORS (e.g. https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5173
